# ──────────────────────────────────────────────
# regen-market-monitor configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# REQUIRED — URL of the regen-compute MCP server
# This is the HTTP endpoint that accepts MCP tool calls
REGEN_COMPUTE_MCP_URL=http://localhost:3100/mcp

# OPTIONAL (recommended) — Telegram bot for alert delivery
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=
# Chat ID where alerts are sent (channel, group, or DM)
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Polling intervals
# ──────────────────────────────────────────────

# How often to run price + liquidity checks (ms). Default: 3600000 (1 hour)
POLL_INTERVAL_MS=3600000

# ──────────────────────────────────────────────
# Alert thresholds
# ──────────────────────────────────────────────

# Fire low-stock alert when available credits drop below this. Default: 1000
LOW_STOCK_THRESHOLD=1000

# Fire price-move alert when price changes more than this fraction. Default: 0.10 (10%)
PRICE_MOVE_THRESHOLD=0.10

# Don't re-fire the same alert within this window (ms). Default: 3600000 (1 hour)
ALERT_COOLDOWN_MS=3600000

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal. Default: info
LOG_LEVEL=info
