# ──────────────────────────────────────────────
# regen-market-monitor configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# REQUIRED — URL of the regen-compute MCP server
REGEN_COMPUTE_MCP_URL=http://localhost:3100/mcp

# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────

# Bot token from @BotFather (optional but recommended)
TELEGRAM_BOT_TOKEN=
# Chat ID where alerts are sent
TELEGRAM_CHAT_ID=
# REQUIRED for proposal approval — only this chat ID can /approve or /reject proposals
TELEGRAM_ADMIN_CHAT_ID=

# ──────────────────────────────────────────────
# Polling intervals
# ──────────────────────────────────────────────

# Market monitoring poll interval (ms). Default: 3600000 (1 hour)
POLL_INTERVAL_MS=3600000

# ──────────────────────────────────────────────
# Alert thresholds
# ──────────────────────────────────────────────

LOW_STOCK_THRESHOLD=1000
PRICE_MOVE_THRESHOLD=0.10
ALERT_COOLDOWN_MS=3600000

# ──────────────────────────────────────────────
# Health endpoint
# ──────────────────────────────────────────────

PORT=3099

# ──────────────────────────────────────────────
# Daily digest
# ──────────────────────────────────────────────

DAILY_DIGEST_HOUR_UTC=9

# ──────────────────────────────────────────────
# Data persistence
# ──────────────────────────────────────────────

DATA_DIR=./data

# ──────────────────────────────────────────────
# MCP connection
# ──────────────────────────────────────────────

MCP_TIMEOUT_MS=10000
MCP_RETRY_ATTEMPTS=3

# ──────────────────────────────────────────────
# Regen Network chain (on-chain action layer)
# ──────────────────────────────────────────────

# Regen LCD (REST API) for direct chain queries. Default: https://regen.api.boz.moe
REGEN_LCD_URL=https://regen.api.boz.moe

# Regen Tendermint RPC for transaction signing/broadcasting
REGEN_RPC_URL=https://regen-rpc.polkachu.com

# BIP39 mnemonic for the proposal submission wallet.
# REQUIRED for governance proposal submission. KEEP SECRET — never commit this.
# If not set, monitoring runs but proposal submission is disabled.
REGEN_MNEMONIC=

# Chain ID. Default: regen-1
REGEN_CHAIN_ID=regen-1

# Gas price for transactions. Default: 0.015uregen
REGEN_GAS_PRICE=0.015uregen

# Gas multiplier applied to simulation estimate. Default: 1.3
GAS_MULTIPLIER=1.3

# ──────────────────────────────────────────────
# Event watcher (chain event polling)
# ──────────────────────────────────────────────

# How often to poll LCD for new chain events (ms). Default: 60000 (1 minute)
EVENT_POLL_INTERVAL_MS=60000

# Sell orders above this USD value trigger immediate liquidity assessment. Default: 10000
LARGE_TRADE_THRESHOLD_USD=10000

# ──────────────────────────────────────────────
# Proposals
# ──────────────────────────────────────────────

# Time before a pending proposal auto-expires (ms). Default: 3600000 (1 hour)
PROPOSAL_EXPIRY_MS=3600000

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────

LOG_LEVEL=info

# ──────────────────────────────────────────────
# Cross-Chain Intelligence
# ──────────────────────────────────────────────

# Hydrex MetaDEX API for primary Base venue. Default: https://api.hydrex.fi
HYDREX_API_URL=https://api.hydrex.fi
# Osmosis LCD for DEX pool queries. Default: https://lcd.osmosis.zone
OSMOSIS_LCD_URL=https://lcd.osmosis.zone
# Axelar API for bridge flow tracking. Default: https://api.axelarscan.io
AXELAR_API_URL=https://api.axelarscan.io
# Base chain RPC for Aerodrome pool queries. Default: https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org
# Celo RPC for Uniswap V3. Default: https://forno.celo.org
CELO_RPC_URL=https://forno.celo.org
# CoinGecko API key (optional, enables pro tier with higher rate limits)
COINGECKO_API_KEY=
# CoinGecko cache TTL (ms). Default: 300000 (5 minutes)
COINGECKO_CACHE_TTL_MS=300000
# Minimum gross spread % to analyze for arbitrage. Default: 2.0
ARBIT_DETECTION_THRESHOLD=2.0
# Minimum net spread % (after fees) to flag as profitable. Default: 1.0
ARBIT_MIN_PROFIT_PCT=1.0
# Bridge flow thresholds (REGEN units) for accumulation/distribution signals
FLOW_ACCUMULATION_THRESHOLD=10000
FLOW_DISTRIBUTION_THRESHOLD=10000
# Cross-chain fetch timeout (ms). Default: 30000
CROSS_CHAIN_TIMEOUT_MS=30000
# How often to refresh venue contracts (days). Default: 7
VENUE_DISCOVERY_TTL_DAYS=7

# ──────────────────────────────────────────────
# Whale Wallet Tracker
# ──────────────────────────────────────────────

WHALE_ENABLED=true
WHALE_POLL_INTERVAL_MS=300000
WHALE_CRITICAL_THRESHOLD_REGEN=500000
WHALE_HIGH_THRESHOLD_REGEN=100000
WHALE_MEDIUM_THRESHOLD_REGEN=10000

# ──────────────────────────────────────────────
# Trading Signal Engine
# ──────────────────────────────────────────────

# Hard cap on recommended trade size (USD). Default: 5000
MAX_SIGNAL_SIZE_USD=5000
# Minimum conviction to broadcast via Telegram (A/B/C). Default: C
SIGNAL_MIN_CONVICTION=C
# If true, only Telegram-notify conviction A signals. Default: false
SIGNAL_BROADCAST_A_ONLY=false

# ──────────────────────────────────────────────
# Execution (Bankr)
# ──────────────────────────────────────────────

# Master switch — agent never executes without explicit true
EXECUTION_ENABLED=false
# Max USD buying REGEN per day
DAILY_BUY_CAP_USD=100
# Max USD selling REGEN per day
DAILY_SELL_CAP_USD=50
# Hard cap per single order
SINGLE_ORDER_MAX_USD=50
# Above this requires Telegram approval
EXECUTION_THRESHOLD_USD=20
# Reject trades with higher price impact
MAX_PRICE_IMPACT_PCT=2.0

# ──────────────────────────────────────────────
# Accumulation Strategy
# ──────────────────────────────────────────────

# Don't buy REGEN above this price
ACCUMULATION_PRICE_CAP_USD=0.05
# Minimum Hydrex pool TVL to execute
ACCUMULATION_MIN_TVL_USD=10000
# DCA interval when no epoch signal (hours)
ACCUMULATION_INTERVAL_HOURS=4

# ──────────────────────────────────────────────
# Coinstore Volume Strategy
# ──────────────────────────────────────────────

# Coinstore API credentials (HMAC-SHA256 signing). KEEP SECRET.
COINSTORE_API_KEY=
COINSTORE_API_SECRET=
# Below this = delisting risk, act immediately
COINSTORE_MIN_DAILY_VOLUME_USDT=500
# Healthy volume target
COINSTORE_TARGET_DAILY_VOLUME_USDT=2000
# Market making spread % (each side)
COINSTORE_MM_SPREAD_PCT=1.0
# Size of each MM order (USDT)
COINSTORE_MM_ORDER_SIZE_USDT=25
# How often to cancel and replace MM orders (ms)
COINSTORE_MM_REFRESH_INTERVAL_MS=300000
# Volume boost explicit opt-in
COINSTORE_VOLUME_BOOST_ENABLED=false
# Size of each volume boost buy (USDT)
COINSTORE_BOOST_SIZE_USDT=15
# Trade approval timeout (ms). Default: 15min
TRADE_APPROVAL_TIMEOUT_MS=900000

# ──────────────────────────────────────────────
# LP Position Manager
# ──────────────────────────────────────────────

# Master switch — never manages LP without explicit true
LP_ENABLED=false
# Max USD in LP at any time
LP_MAX_POSITION_USD=200
# Minimum APR to enter LP
LP_MIN_APR_PCT=200
# Don't LP too close to epoch flip (hours)
LP_MIN_HOURS_TO_EPOCH=12
# Exit LP if IL exceeds this %
LP_MAX_IL_PCT=15
# Exit if LP losing more than this vs hold %
LP_MIN_NET_POSITION_PCT=-5
# Max price drift before re-entry review %
LP_PRICE_RANGE_PCT=20
# Minimum REGEN to LP
LP_MIN_REGEN_AMOUNT=1000
# Minimum reward value to claim (USD)
LP_MIN_CLAIM_USD=5
# Auto-convert HYDX rewards to REGEN
HYDX_AUTO_COMPOUND=false

# ──────────────────────────────────────────────
# GMX (perp trading on Arbitrum)
# ──────────────────────────────────────────────

# Private key for EIP-712 signing. Paper mode works without it.
GMX_PK=
# Paper mode by default — set to false for live execution
GMX_DRY_RUN=true
# Max daily spend (USD). Default: 50
GMX_DAILY_CAP=50
# Max single position (USD). Default: 25
GMX_MAX_POSITION=25
# Max leverage (GMX supports 100x; capped at 10). Default: 10
GMX_MAX_LEVERAGE=10
# Min annualized funding rate to trade. Default: 1%
GMX_FUNDING_THRESHOLD=0.01
# Min 24h price change for momentum. Default: 2%
GMX_MOMENTUM_THRESHOLD=0.02
# Min 24h volume to consider. Default: 1M
GMX_MIN_VOLUME=1000000
# Chain ID (42161=Arbitrum, 43114=Avalanche). Default: 42161
GMX_CHAIN_ID=42161
# Arbitrum RPC URL (defaults to public endpoint)
GMX_RPC_URL=
# Enable GM pool LP yield scanning (signal-only). Default: false
GMX_GM_POOL_ENABLED=false
# Min APY to flag a GM pool opportunity. Default: 10%
GMX_GM_MIN_APY=10

# ──────────────────────────────────────────────
# LITCREDIT Relay (AI scoring for all venues)
# ──────────────────────────────────────────────

# Wallet address for X-Wallet auth (preferred)
LITCOIN_WALLET=
# API key for Bearer auth (fallback)
LITCOIN_RELAY_KEY=
# Relay URL. Default: https://api.litcoiin.xyz/v1
LITCREDIT_RELAY_URL=https://api.litcoiin.xyz/v1
# Model for scoring. Default: auto
LITCREDIT_MODEL=auto
# Timeouts (ms)
LITCREDIT_TIMEOUT_MS=45000
LITCREDIT_RETRY_TIMEOUT_MS=120000

# ──────────────────────────────────────────────
# Hyperliquid (perp trading)
# ──────────────────────────────────────────────

# Private key for signing orders. Paper mode works without it.
HYPERLIQUID_PK=
# Paper mode by default — set to false for live execution
HYPERLIQUID_DRY_RUN=true
# Max daily spend (USD). Default: 50
HYPERLIQUID_DAILY_CAP=50
# Max single position (USD). Default: 25
HYPERLIQUID_MAX_POSITION=25
# Max leverage. Default: 5
HYPERLIQUID_MAX_LEVERAGE=5
# Min annualized funding rate to trade. Default: 1%
HYPERLIQUID_FUNDING_THRESHOLD=0.01
# Min 24h price change to trade momentum. Default: 2%
HYPERLIQUID_MOMENTUM_THRESHOLD=0.02
# Min 24h volume to consider. Default: 1M
HYPERLIQUID_MIN_VOLUME=1000000

# ──────────────────────────────────────────────
# Polymarket (prediction markets)
# ──────────────────────────────────────────────

# CLOB credentials for live execution. Paper mode works without them.
POLYMARKET_PK=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
# Paper mode by default — set to false for live execution
POLYMARKET_DRY_RUN=true
# Max daily spend (USD). Default: 50
POLYMARKET_DAILY_CAP=50
# Max single bet (USD). Default: 15
POLYMARKET_MAX_BET=15
# Min divergence vs crowd to trade. Default: 12%
POLYMARKET_MIN_EDGE=0.12
# Min market liquidity. Default: 50K
POLYMARKET_MIN_LIQUIDITY=50000
# Max bid/ask spread. Default: 6%
POLYMARKET_MAX_SPREAD=0.06
# Cooldown between trades (ms). Default: 30s
POLYMARKET_COOLDOWN_MS=30000

# ──────────────────────────────────────────────
# Trading Desk (surplus routing)
# ──────────────────────────────────────────────

# Route surplus to REGEN when cumulative P&L exceeds this (USD). Default: 50
TRADING_DESK_SURPLUS_FLOOR=50
# % of surplus to route to REGEN accumulation. Default: 20
TRADING_DESK_SURPLUS_PCT=20
# Run multi-venue scan inside monitor process (ms, 0=disabled). Default: 0
TRADING_DESK_INTERVAL_MS=0

# ──────────────────────────────────────────────
# Multi-Agent Signal Broadcasting
# ──────────────────────────────────────────────

# Redis Streams — enables real-time signal publishing to downstream agents.
# If not set, signals are stored locally and available via REST /signals only.
REDIS_URL=
# Stream key for all signals. Default: regen:market:signals
REDIS_STREAM_KEY=regen:market:signals
# Max entries in each Redis stream. Default: 10000
REDIS_STREAM_MAXLEN=10000

# Webhooks — comma-separated list of HTTP endpoints for signal delivery.
# If not set, webhook publishing is disabled.
WEBHOOK_URLS=
# HMAC-SHA256 secret for signing webhook payloads. Optional.
WEBHOOK_SECRET=
# Comma-separated AgentIds to filter webhook delivery (e.g. AGENT-001,AGENT-002). Optional.
WEBHOOK_AGENT_FILTER=

# Signal store — in-memory ring buffer size. Default: 500
SIGNAL_STORE_SIZE=500

# Server-Sent Events — max concurrent SSE connections. Default: 10
SSE_MAX_CONNECTIONS=10
