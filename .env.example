# ──────────────────────────────────────────────
# regen-market-monitor configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# REQUIRED — URL of the regen-compute MCP server
# This is the HTTP endpoint that accepts MCP tool calls
REGEN_COMPUTE_MCP_URL=http://localhost:3100/mcp

# OPTIONAL (recommended) — Telegram bot for alert delivery
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=
# Chat ID where alerts are sent (channel, group, or DM)
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────
# Polling intervals
# ──────────────────────────────────────────────

# How often to run price + liquidity checks (ms). Default: 3600000 (1 hour)
POLL_INTERVAL_MS=3600000

# ──────────────────────────────────────────────
# Alert thresholds
# ──────────────────────────────────────────────

# Fire low-stock alert when available credits drop below this. Default: 1000
LOW_STOCK_THRESHOLD=1000

# Fire price-move alert when price changes more than this fraction. Default: 0.10 (10%)
PRICE_MOVE_THRESHOLD=0.10

# Don't re-fire the same alert within this window (ms). Default: 3600000 (1 hour)
ALERT_COOLDOWN_MS=3600000

# ──────────────────────────────────────────────
# Health endpoint
# ──────────────────────────────────────────────

# HTTP port for /health and /state endpoints. Default: 3099
PORT=3099

# ──────────────────────────────────────────────
# Daily digest
# ──────────────────────────────────────────────

# UTC hour (0-23) to send the daily Telegram digest. Default: 9 (09:00 UTC)
DAILY_DIGEST_HOUR_UTC=9

# ──────────────────────────────────────────────
# Data persistence
# ──────────────────────────────────────────────

# Directory for persistent JSON files (price history, alert state, snapshots).
# Created automatically if it doesn't exist. Default: ./data
DATA_DIR=./data

# ──────────────────────────────────────────────
# MCP connection
# ──────────────────────────────────────────────

# Timeout per MCP tool call in ms. Default: 10000 (10 seconds)
MCP_TIMEOUT_MS=10000

# Number of retry attempts for failed MCP calls (exponential backoff 1s/2s/4s). Default: 3
MCP_RETRY_ATTEMPTS=3

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal. Default: info
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Multi-Agent Signal Broadcasting
# ──────────────────────────────────────────────

# Redis Streams — enables real-time signal publishing to downstream agents.
# If not set, signals are stored locally and available via REST /signals only.
REDIS_URL=
# Stream key for all signals. Default: regen:market:signals
REDIS_STREAM_KEY=regen:market:signals
# Max entries in each Redis stream. Default: 10000
REDIS_STREAM_MAXLEN=10000

# Webhooks — comma-separated list of HTTP endpoints for signal delivery.
# If not set, webhook publishing is disabled.
WEBHOOK_URLS=
# HMAC-SHA256 secret for signing webhook payloads. Optional.
WEBHOOK_SECRET=
# Comma-separated AgentIds to filter webhook delivery (e.g. AGENT-001,AGENT-002). Optional.
WEBHOOK_AGENT_FILTER=

# Signal store — in-memory ring buffer size. Default: 500
SIGNAL_STORE_SIZE=500

# Server-Sent Events — max concurrent SSE connections. Default: 10
SSE_MAX_CONNECTIONS=10
