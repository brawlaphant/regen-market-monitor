{
  "name": "regen-market-monitor",
  "version": "0.1.0",
  "description": "ElizaOS agent implementing AGENT-003 (RegenMarketMonitor) — autonomous Regen Network ecocredit market surveillance",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tune": "tsx src/tuner/cli.ts",
    "trading-desk": "TRADING_DESK_INTERVAL_MS=0 tsx src/trading-desk.ts",
    "trading-desk:dry": "POLYMARKET_DRY_RUN=true HYPERLIQUID_DRY_RUN=true tsx src/trading-desk.ts",
    "trading-desk:live": "POLYMARKET_DRY_RUN=false HYPERLIQUID_DRY_RUN=false tsx src/trading-desk.ts"
  },
  "dependencies": {
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@gmx-io/sdk": "^1.5.0-alpha-9",
    "@polymarket/clob-client": "^5.8.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "hyperliquid": "^1.7.7",
    "ioredis": "^5.10.1",
    "node-telegram-bot-api": "^0.66.0",
    "pino": "^9.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@elizaos/core": "^0.x",
    "@elizaos/plugin-node": "^0.x"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": {
      "optional": true
    },
    "@elizaos/plugin-node": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
